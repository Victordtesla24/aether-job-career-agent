# =============================================================================
# Aether — Environment Variable Template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# `.env` is git-ignored. Do not paste real secrets into `.env.example`.
# =============================================================================

# ---- AI / LLM providers ----
# Primary multi-model gateway used by the agent layer.
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional direct provider keys (fallbacks / specific agents)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/aether

# ---- Vector store (semantic search / embeddings) ----
PINECONE_API_KEY=
PINECONE_INDEX=aether

# ---- Auth (NextAuth) ----
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# ---- Web app ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- API app ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Observability (optional) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
