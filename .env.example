# =============================================================================
# Aether — Environment Variable Template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# `.env` is git-ignored. Do not paste real secrets into `.env.example`.
# =============================================================================

# ---- AI / LLM providers ----
# Primary multi-model gateway used by the agent layer.
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Model tiers (Phase 2) ----
# Reasoning-heavy tasks (resume tailoring, cover letters).
AETHER_MODEL_REASONING=deepseek/deepseek-chat-v3-0324:free
# Fast classification (scout agent).
AETHER_MODEL_FAST=meta-llama/llama-3.3-70b-instruct:free
# Reliable structured/JSON output (story extractor).
AETHER_MODEL_STRUCTURED=qwen/qwen-2.5-72b-instruct:free
# Lightweight validation / cheap agent tests (<= 20 tokens).
AETHER_MODEL_LIGHT=meta-llama/llama-3.1-8b-instruct:free
# Legacy Phase 1 aliases (kept for back-compat).
AETHER_MODEL_HEAVY=meta-llama/llama-3.3-70b-instruct:free

# LLM record/replay mode for agent tests: replay (default, offline, no key),
# record (call live model + save fixture), or auto (replay if present else record).
# CI runs `replay`; only `record`/`auto` need OPENROUTER_API_KEY.
AETHER_LLM_MODE=auto

# Optional direct provider keys (fallbacks / specific agents)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ---- Database ----
DATABASE_URL=postgresql://aether:aether@localhost:5432/aether
# Separate database for integration/repository tests.
DATABASE_URL_TEST=postgresql://aether:aether@localhost:5432/aether_test

# ---- Queue (BullMQ / Redis) ----
REDIS_URL=redis://localhost:6379

# ---- Vector store (semantic search / embeddings) ----
PINECONE_API_KEY=
PINECONE_INDEX=aether

# ---- Auth (NextAuth) ----
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# ---- Web app ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- API app ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Job board adapters (no API keys needed — HTML scrapers) ----
SEEK_BASE_URL=https://www.seek.com.au
LINKEDIN_BASE_URL=https://www.linkedin.com/jobs
INDEED_BASE_URL=https://au.indeed.com

# ---- Sentence-transformers model cache (ATS engine) ----
SENTENCE_TRANSFORMERS_HOME=/tmp/aether_models

# ---- spaCy model (fabrication guard, Phase 2 S06) ----
SPACY_MODEL=en_core_web_sm

# ---- Observability (optional) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
