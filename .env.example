# =============================================================================
# Aether — Environment Variable Template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# `.env` is git-ignored. Do not paste real secrets into `.env.example`.
# =============================================================================

# ---- AI / LLM providers ----
# Primary multi-model gateway used by the agent layer.
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model tiers used by the agent layer (override to taste).
# Phase 2 tiers: reasoning (planning/complex), fast (general), structured
# (JSON extraction), light (cheap classification / smoke checks).
AETHER_MODEL_REASONING=openai/gpt-oss-120b:free
AETHER_MODEL_FAST=meta-llama/llama-3.3-70b-instruct:free
AETHER_MODEL_STRUCTURED=qwen/qwen3-next-80b-a3b-instruct:free
AETHER_MODEL_LIGHT=meta-llama/llama-3.2-3b-instruct:free
# Legacy alias kept for Phase 1 scripts.
AETHER_MODEL_HEAVY=meta-llama/llama-3.3-70b-instruct:free
# Fallback model tried when the primary model fails/times out (ADR D-0017).
AETHER_MODEL_FALLBACK=openai/gpt-oss-20b:free
# Optional provider override: point the agent layer at any OpenAI-compatible
# endpoint (e.g. Anthropic's https://api.anthropic.com/v1 with an Anthropic API
# key and Claude model ids in the AETHER_MODEL_* vars). When unset, OpenRouter
# (OPENROUTER_BASE_URL/OPENROUTER_API_KEY) is used.
AETHER_LLM_BASE_URL=
AETHER_LLM_API_KEY=
# Extra HTTP headers (JSON object) sent on every live LLM call. Required by
# Anthropic's OpenAI-compat endpoint, e.g.:
# AETHER_LLM_EXTRA_HEADERS={"anthropic-version":"2023-06-01","anthropic-beta":"oauth-2025-04-20"}
# (the anthropic-beta header is only needed for OAuth/subscription tokens)
AETHER_LLM_EXTRA_HEADERS=
# Claude Code OAuth token (GAP-P7-DEF-A). Written HERE automatically by the
# server when a user saves a `claude setup-token` credential (sk-ant-oat01-…) in
# the Agents → Configure Anthropic modal; oauth_token runs bill against the
# Claude Pro/Max subscription. Do NOT paste secrets into this example file —
# the real value lands in the gitignored repo-root .env (600 perms). Override the
# target path with AETHER_ENV_FILE_PATH if the repo lives elsewhere.
# CLAUDE_CODE_OAUTH_TOKEN=
# LLM record/replay mode for agent tests: replay (default, offline, no key),
# record (call live model + save fixture), auto (replay if present else record),
# or live (always call the live model). CI runs `replay`; only `record`/`auto`/
# `live` need OPENROUTER_API_KEY.
# SAFETY: the API refuses to start (RuntimeError, §REC-04) if AETHER_LLM_MODE
# is left at its `replay` default while AETHER_ENV=production — that combo
# would silently serve canned fixtures instead of real model output. Set this
# to `auto`, `live`, or `record` in production.
AETHER_LLM_MODE=replay

# Deployment environment: development (default) or production. Only affects
# fail-fast safety guards (see AETHER_LLM_MODE above); does not change app
# behavior otherwise. Set to `production` on the production deploy.
AETHER_ENV=development

# Optional direct provider keys (fallbacks / specific agents)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ---- Google OAuth (Gmail integration, P4) ----
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console,
# enable the Gmail API, add scopes gmail.modify / gmail.send / gmail.labels +
# openid / email / profile, and register the redirect URI below as an authorized
# redirect URI. While the app is in "testing", add yourself as a test user.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must EXACTLY match an authorized redirect URI on the OAuth client. In prod:
# https://<your-host>/api/auth/google/callback  (nginx proxies /api/* → FastAPI).
GOOGLE_OAUTH_REDIRECT_URI=
# OPTIONAL. Dedicated secret for signing the short-lived OAuth `state` token.
# Left unset, it derives from NEXTAUTH_SECRET but is namespaced so it can never
# equal the app session-signing secret — a state token can never be replayed as
# a session token. Set this only to fully isolate the two key materials.
GOOGLE_OAUTH_STATE_SECRET=

# ---- Database ----
# Hosted PostgreSQL. When the provider only grants a single database, use
# separate schemas for dev/test via Prisma's `?schema=` parameter.
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=aether&connect_timeout=15"
# Separate test database/schema for integration tests (repository tests skip if unset).
DATABASE_URL_TEST="postgresql://user:password@host:5432/dbname?schema=aether_test&connect_timeout=15"

# ---- Queue (BullMQ / Redis) ----
REDIS_URL=redis://localhost:6379

# ---- Vector store (semantic search / embeddings) ----
PINECONE_API_KEY=
PINECONE_INDEX=aether

# ---- Auth (NextAuth) ----
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# ---- Web app ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- API app ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Internal-use email allowlist (GAP-P7-DEF-B / §15) ----
# Comma-separated internal domains to allow in email validation. Without
# this, pydantic's EmailStr (via email-validator) rejects any domain in its
# reserved Special-Use list (.local, .test, .onion, .arpa, .invalid,
# "localhost") regardless of check_deliverability — e.g. a stored/seeded
# admin@aether.local account cannot save its own settings. Only the exact
# domain(s) listed here are opened; every other special-use domain stays
# rejected.
AETHER_ALLOWED_INTERNAL_EMAIL_DOMAINS=aether.local

# ---- Observability (optional) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---- Job board sources (Phase 2 discovery agents) ----
SEEK_BASE_URL=https://www.seek.com.au
LINKEDIN_BASE_URL=https://www.linkedin.com/jobs
INDEED_BASE_URL=https://au.indeed.com

# ---- NLP / embeddings (Phase 2 matching) ----
SENTENCE_TRANSFORMERS_HOME=/tmp/aether_models
SPACY_MODEL=en_core_web_sm

# ---- Async background generation (GAP-P7-ASYNC-001, Phase 7) ----
# Code default OFF. Flip to true only after the J3 soak (see
# deploy/PHASE7-ASYNC-DEPLOY.md). When OFF, run endpoints stay synchronous 200.
AETHER_ASYNC_GENERATION=false
# Redis password (openssl rand -hex 24) + URL on a dedicated logical DB (3).
AETHER_REDIS_PASSWORD=
AETHER_REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379/3
# Worker-side LLM budgets (seconds) — more generous than the HTTP edge budgets;
# MUST stay below the ARQ job_timeout (600s).
AETHER_LLM_WORKER_BUDGET_SECONDS=300
AETHER_LLM_WORKER_COVER_BUDGET_SECONDS=300
AETHER_LLM_WORKER_PIPELINE_BUDGET_SECONDS=480
# Watchdog: mark a job failed+refunded if stuck past this many seconds (enqueued;
# processing window = this - 180). Default 900 (15 min).
AETHER_JOB_STALE_SECONDS=900

# ---- Discovery cron system-run exemption (ADR-P7-05 / GAP-P7-DISCOVERY-001) ----
# Shared secret scripts/discovery_cron.sh sends as the X-Aether-System-Run
# header so the API can bypass ONLY the subscription-paywall check (never any
# other guard), and ONLY for the discovery pipeline's own scout/fit-scorer
# calls -- never any other agent. Leave unset to disable the exemption
# entirely (the header is then ignored, not a bypass-by-omission). NEVER
# commit a real value here: the deployer generates a fresh random secret
# (e.g. `openssl rand -hex 32`) at deploy time and sets it only in the real
# `.env` (600 permissions, never logged).
AETHER_SYSTEM_RUN_SECRET=
