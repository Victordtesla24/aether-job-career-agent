# ============================================================================
# AETHER — Environment Template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.  `.env` is git-ignored and
# must NEVER be committed.  The only value YOU must provide to get started is
# OPENROUTER_API_KEY — paste a real key from https://openrouter.ai/keys
# ============================================================================

# --- OpenRouter (LLM provider for testing / validation) --------------------
# REQUIRED. Get a key at https://openrouter.ai/keys  (free tier is sufficient
# for the free/open-source models listed below). Never commit the real key.
OPENROUTER_API_KEY=

# OpenAI-compatible base URL for OpenRouter. Leave as-is unless self-routing.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional attribution headers (recommended by OpenRouter).
OPENROUTER_HTTP_REFERER=https://github.com/Victordtesla24/aether-job-career-agent
OPENROUTER_APP_TITLE=Aether

# --- Free / open-source models used for tests, verification & validation ----
# These are configuration, not code. If a model is rate-limited or removed
# from the free tier, the app falls back through this list (and logs the
# substitution). Do NOT switch tests to paid models silently.
AETHER_MODEL_REASONING=deepseek/deepseek-chat-v3-0324:free
AETHER_MODEL_FAST=meta-llama/llama-3.3-70b-instruct:free
AETHER_MODEL_STRUCTURED=qwen/qwen-2.5-72b-instruct:free
AETHER_MODEL_LIGHT=meta-llama/llama-3.1-8b-instruct:free

# Determinism knobs for reproducible LLM tests.
AETHER_LLM_TEMPERATURE=0
AETHER_LLM_SEED=42

# --- Datastores (local dev defaults) ---------------------------------------
DATABASE_URL=postgresql://aether:aether@localhost:5432/aether
REDIS_URL=redis://localhost:6379

# --- Auth (generate real secrets locally; never commit) --------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth providers (optional until Phase 1 auth slice).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Observability (optional) ----------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
