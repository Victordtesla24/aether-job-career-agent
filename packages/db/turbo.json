{
  "extends": ["//"],
  "tasks": {
    "prisma:generate": {
      "cache": false,
      "inputs": ["src/schema.prisma"]
    },
    "build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": ["dist/**"]
    },
    "type-check": {
      "dependsOn": ["^build", "prisma:generate"]
    },
    "test": {
      "dependsOn": ["^build", "prisma:generate"]
    }
  }
}
